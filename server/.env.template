# OpenAI APIキー
OPENAI_API_KEY=your_openai_api_key_here

# APIを使用するかのフラグ (true/false)
# falseの場合、テストモードとなりOpenAI APIは使用せず、固定テキストが返されます
USE_API=true

# テストモード設定
# テストモード用のレスポンスパターン（カンマ区切りで複数指定可能、ランダムに選ばれます）
TEST_RESPONSES=こんにちは！テストモードでの返答です。OpenAIには接続していません,テストモードですので、料金はかかりません。安心してください,テスト返答その3です。色々なパターンを用意すると面白いですね,開発中はテストモードが便利です。本番環境では必ずAPIを使ってくださいね

# 音声合成サービス選択（'azure'、'voicevox'、'dummy'など）
TTS_SERVICE=voicevox

# Azure Cognitive Services (Speech) 設定
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_REGION=japaneast
# 日本語の女性音声（他のオプション: ja-JP-KeitaNeural(男性), ja-JP-AoiNeural(女性), etc）
AZURE_TTS_VOICE=ja-JP-NanamiNeural

# VOICEVOX設定（ローカルサーバーを実行している場合）
VOICEVOX_ENDPOINT=http://localhost:50021
# スピーカーID (例: 1=四国めたん, 2=ずんだもん, 3=春日部つむぎ, etc）
VOICEVOX_SPEAKER_ID=1

# サーバー設定
PORT=3000